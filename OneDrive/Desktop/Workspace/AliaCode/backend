/* Constants: Defines various constants such as backend URL, iframe ID, shop URL, and JWT headers.  */
    

    const BACKEND_URL = "https://backend.alia-cloudflare.com";
    const IFRAME_ID = "alia-iframe";
    const SHOP_URL = "ja0bsa-pw.myshopify.com";
    const IS_MOBILE_HEADER = "x-alia-is-mobile";
    const JWT_HEADER = "x-alia-jwt";
    const ALIA_JWT_KEY = "alia-jwt";


/* Helper Functions: These functions handle various tasks such as getting the current URL, 
    saving and retrieving JWTs, and checking if the user is on a mobile device.
   ChatGPT = JWT Management: Functions to save, retrieve, and clear a JWT (JSON Web Token) from 
   local storage.
*/


    function saveAliaJWT(jwt) {
      localStorage.setItem(ALIA_JWT_KEY, jwt);
    }
    function getAliaJWT() {
      return localStorage.getItem(ALIA_JWT_KEY);
    }
    function clearAliaJWT() {
      localStorage.removeItem(ALIA_JWT_KEY);
    }



/* Initial Data Fetch: getAliaInit function constructs a request to fetch initial data 
for the widget from the backend, including user information like IP address and user agent.
It handles parameters based on the device dimensions and URL. */


    async function getAliaInit(shopURL, customerID, showByDefault) {
      const url = new URL(BACKEND_URL);
      url.pathname = "/user/users/init";

      // verify request params
      url.searchParams.append("shop", shopURL);
      url.searchParams.append("shopify_customer_id", customerID);
      const ipAddress = await aliaGetIPAddress();
      if (ipAddress) {
        url.searchParams.append("ip_address", ipAddress);
      }
      const userAgent = navigator.userAgent;
      if (userAgent) {
        url.searchParams.append("user_agent", userAgent);
      }

      // customer app params
      url.searchParams.append(
        "width",
        Math.min(window.innerWidth, window.outerWidth)
      );
      url.searchParams.append("height", window.innerHeight);
      url.searchParams.append("path", window.location.pathname + location.search);
      if (showByDefault) url.searchParams.append("initial_state", "maximized");

      const response = await fetch(url.toString(), {
        headers: {
          [JWT_HEADER]: getAliaJWT(),
          [IS_MOBILE_HEADER]: aliaIsMobile() ? "true" : "false",
        },
      });
      if (response.ok) {
        const newJWT = response.headers.get(JWT_HEADER);
        if (newJWT) {
          saveAliaJWT(response.headers.get(JWT_HEADER));
        }
        return await response.json();
      }
    }
    async function aliaGetIPAddress() {
      try {
        const response = await fetch("https://api.ipify.org");
        if (response.status !== 200) return undefined;
        return await response.text();
      } catch (e) {
        return undefined;
      }
    }

    /*  Widget Creation:
    createAliaWidget (125) sets up the iframe on the webpage, ensuring it is created only once.
    initAlia (144) initializes the widget based on the response from the server.    */

