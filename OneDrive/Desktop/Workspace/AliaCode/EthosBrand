/**
 * Integrations for Klaviyo, Postscript, and Shopify Analytics
 */

/**
 * Integrate with Klaviyo
 * @param {Object} profile - User profile data
 */
function integrateKlaviyo(profile) {
    if (window.klaviyo) {
        window.klaviyo.identify({
            email: profile.email || '',
            first_name: profile.name || '',
            phone_number: profile.phone || ''
        });
    }
}

/**
 * Integrate with Postscript
 * @param {Object} profile - User profile data
 */
function integratePostscript(profile) {
    if (window.postscript) {
        window.postscript.identify({
            phone: profile.phone || '',
            email: profile.email || ''
        });
    }
}

/**
 * Integrate with Shopify Analytics
 * @param {Object} profile - User profile data
 */
function integrateShopifyAnalytics(profile) {
    if (window.Shopify && window.Shopify.analytics) {
        window.Shopify.analytics.publish("yotpo_identify_customer", {
            email: profile.email || '',
            phone: profile.phone || ''
        });
    }
}

/**
 * Main function to handle user identification
 * @param {Object} userProfile - User profile data that includes name, email, and phone
 */
function handleUserIdentification(userProfile) {
    integrateKlaviyo(userProfile);
    integratePostscript(userProfile);
    integrateShopifyAnalytics(userProfile);
}

// Example user profile to pass to the integration functions
